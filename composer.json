{
    "name": "prestapro/pp-omniva",
    "description": "PrestaPro — Omniva shipping module for PrestaShop 9",
    "type": "prestashop-module",
    "license": "AFL-3.0",
    "authors": [
        {
            "name": "PrestaPro",
            "homepage": "https://prestapro.lt"
        }
    ],
    "autoload": {
        "psr-4": {
            "PrestaShop\\Module\\PPOmniva\\": "src/"
        },
        "classmap": [
            "ppomniva.php"
        ]
    },
    "require": {
        "php": ">=8.1",
        "prestapro/pp-common": "dev-main"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/PrestaProLT/pp-common.git"
        }
    ],
    "config": {
        "prepend-autoloader": false,
        "sort-packages": true,
        "autoloader-suffix": "PPOmniva100"
    }
}
