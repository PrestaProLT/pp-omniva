{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
{{ include('@Modules/ppomniva/views/templates/admin/partials/_admin_menu.html.twig', {
    active_tab: 'cod',
    page_title: 'Cash on Delivery'|trans({}, 'Modules.Ppomniva.Admin'),
    page_description: 'Tick the payment methods that should mark a Omniva shipment as Cash on Delivery. The COD amount and currency are then sent to Omniva so the courier collects payment from the recipient.'|trans({}, 'Modules.Ppomniva.Admin'),
    multistore_blocked: multistore_blocked,
}) }}

{% if not multistore_blocked %}
<div class="ppo-shell">

{% if orphans|length > 0 %}
<div class="ppo-multistore-warning" style="background: var(--ppo-c-warn-bg);">
    <h4>{{ 'Stale entries'|trans({}, 'Modules.Ppomniva.Admin') }}</h4>
    <p>{{ 'These module names are saved as COD but no longer exist as installed payment modules. Save without ticking them to remove.'|trans({}, 'Modules.Ppomniva.Admin') }}</p>
    <ul style="margin: 4px 0 0 20px;">{% for o in orphans %}<li><code>{{ o }}</code></li>{% endfor %}</ul>
</div>
{% endif %}

<form method="post" action="{{ save_url }}" data-ppo-loading>
    <div class="ppo-card">
        <div class="ppo-card__header">
            <h3 class="ppo-card__title">{{ 'Installed payment methods'|trans({}, 'Modules.Ppomniva.Admin') }}</h3>
            <span class="ppo-card__help">{{ 'Tick a method to mark it as COD. Methods you do not see here are not yet hooked into PrestaShop\'s payment flow.'|trans({}, 'Modules.Ppomniva.Admin') }}</span>
        </div>
        <div class="ppo-card__body">
            {% if available_modules|length == 0 %}
                <div class="ppo-empty">
                    <h4 class="ppo-empty__title">{{ 'No payment methods installed'|trans({}, 'Modules.Ppomniva.Admin') }}</h4>
                    <p class="ppo-empty__body">{{ 'Install at least one payment module (for example, ps_cashondelivery) before marking it as COD.'|trans({}, 'Modules.Ppomniva.Admin') }}</p>
                </div>
            {% else %}
                <div style="margin-bottom: var(--ppo-space-2);">
                    <span class="ppo-bulk-toggle" data-action="all">{{ 'Select all'|trans({}, 'Modules.Ppomniva.Admin') }}</span>
                    &nbsp;·&nbsp;
                    <span class="ppo-bulk-toggle" data-action="none">{{ 'Clear'|trans({}, 'Modules.Ppomniva.Admin') }}</span>
                </div>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--ppo-space-2);">
                    {% for m in available_modules %}
                        <label style="display: flex; align-items: flex-start; gap: var(--ppo-space-2); padding: var(--ppo-space-3); border: 1px solid var(--ppo-border); border-radius: var(--ppo-radius-md); background: var(--ppo-bg-card); cursor: pointer; transition: background-color var(--ppo-duration);"
                               onmouseover="this.style.background='var(--ppo-bg-hover)'" onmouseout="this.style.background='var(--ppo-bg-card)'">
                            <input type="checkbox" name="modules[]" value="{{ m.name }}" {% if m.name in selected %}checked{% endif %} style="margin-top: 2px; flex-shrink: 0;">
                            <span style="flex: 1;">
                                <strong style="color: var(--ppo-text-primary);">{{ m.display_name }}</strong>
                                <small style="display: block; font-family: var(--ppo-font-mono); color: var(--ppo-text-muted); font-size: var(--ppo-text-xs); margin-top: 2px;">{{ m.name }}{% if m.version %} · v{{ m.version }}{% endif %}</small>
                            </span>
                        </label>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    <div class="ppo-form-actions">
        <button type="submit" class="btn btn-primary">{{ 'Save changes'|trans({}, 'Admin.Actions') }}</button>
        <span style="font-size: var(--ppo-text-sm); color: var(--ppo-text-muted);">
            {{ '%count% payment method(s) currently marked as COD.'|trans({'%count%': selected|length}, 'Modules.Ppomniva.Admin') }}
        </span>
    </div>
</form>

</div>

<script>
(function () {
    document.querySelectorAll('.ppo-bulk-toggle').forEach(function (el) {
        el.addEventListener('click', function () {
            var checked = el.dataset.action === 'all';
            document.querySelectorAll('input[name="modules[]"]').forEach(function (cb) { cb.checked = checked; });
        });
    });
})();
</script>
{% endif %}
{% endblock %}
