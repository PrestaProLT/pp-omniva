{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
{% set page_actions %}
    {% if not multistore_blocked and test_connection_url %}
        <button type="button" class="btn btn-secondary" id="ppo-test-connection" data-url="{{ test_connection_url }}">
            {{ 'Test connection'|trans({}, 'Modules.Ppomniva.Admin') }}
        </button>
    {% endif %}
{% endset %}

{{ include('@Modules/ppomniva/views/templates/admin/partials/_admin_menu.html.twig', {
    active_tab: 'configuration',
    page_title: 'Configuration'|trans({}, 'Modules.Ppomniva.Admin'),
    page_description: 'API credentials, checkout fields and shipping options. Settings here apply to the active shop context.'|trans({}, 'Modules.Ppomniva.Admin'),
    multistore_blocked: multistore_blocked,
    multistore_reason: multistore_reason|default(null),
    page_actions: page_actions,
}) }}

{% if not multistore_blocked %}
<div class="ppo-shell">

{# Connection status #}
{% set status_cls = 'unknown' %}
{% if connection_status.connected == true %}{% set status_cls = 'connected' %}
{% elseif connection_status.connected == false %}{% set status_cls = 'disconnected' %}
{% endif %}
<div class="ppo-status ppo-status--{{ status_cls }}" id="ppo-connection-status">
    <span class="ppo-status__dot"></span>
    <span id="ppo-connection-message">
        {{ connection_status.message|default('Click "Test connection" to verify your credentials.'|trans({}, 'Modules.Ppomniva.Admin')) }}
    </span>
</div>

{# Migration card — import data from a previously installed Omniva module #}
{% if legacy_modules|length > 0 %}
    {% for legacy in legacy_modules %}
        <div class="ppo-card ppo-migration" data-migrate-url="{{ migration_migrate_url }}">
            <div class="ppo-card__header">
                <h3 class="ppo-card__title">
                    {{ 'Import from %name%'|trans({'%name%': legacy.display_name|default(legacy.module_name)|default('the legacy module')}, 'Modules.Ppomniva.Admin') }}
                    {% if legacy.version is defined %}<span class="ppo-badge ppo-badge--warn">v{{ legacy.version }}</span>{% endif %}
                </h3>
                <span class="ppo-card__help">{{ 'A previously installed Omniva module was detected. Copy its data into this module, then disable the old one.'|trans({}, 'Modules.Ppomniva.Admin') }}</span>
            </div>
            <div class="ppo-card__body">
                {% if legacy.preview is defined %}
                    <p class="ppo-migration__lead">{{ 'The following will be imported:'|trans({}, 'Modules.Ppomniva.Admin') }}</p>
                    <div class="ppo-migration__stats">
                        {% for table_name, table_info in legacy.preview.tables %}
                            {% if table_info.exists %}
                                <div class="ppo-migration__stat">
                                    <span class="ppo-migration__stat-num">{{ table_info.rows }}</span>
                                    <span class="ppo-migration__stat-label">{{ table_info.label }}</span>
                                </div>
                            {% endif %}
                        {% endfor %}
                        {% if legacy.preview.config_keys is defined %}
                            <div class="ppo-migration__stat">
                                <span class="ppo-migration__stat-num">{{ legacy.preview.config_keys }}</span>
                                <span class="ppo-migration__stat-label">{{ 'Settings'|trans({}, 'Modules.Ppomniva.Admin') }}</span>
                            </div>
                        {% endif %}
                        {% if legacy.preview.carriers is defined %}
                            <div class="ppo-migration__stat">
                                <span class="ppo-migration__stat-num">{{ legacy.preview.carriers|length }}</span>
                                <span class="ppo-migration__stat-label">{{ 'Carriers'|trans({}, 'Modules.Ppomniva.Admin') }}</span>
                            </div>
                        {% endif %}
                    </div>
                    {% if legacy.preview.already_migrated is defined and legacy.preview.already_migrated > 0 %}
                        <p class="ppo-migration__note">{{ '%n% orders were already imported and will be skipped.'|trans({'%n%': legacy.preview.already_migrated}, 'Modules.Ppomniva.Admin') }}</p>
                    {% endif %}
                {% endif %}

                <div class="ppo-migration__actions">
                    <button type="button" class="btn btn-outline-secondary js-ppo-migrate" data-dry="1">{{ 'Preview (dry run)'|trans({}, 'Modules.Ppomniva.Admin') }}</button>
                    <button type="button" class="btn btn-primary js-ppo-migrate" data-dry="0">{{ 'Import now'|trans({}, 'Modules.Ppomniva.Admin') }}</button>
                    <form method="post" action="{{ migration_skip_url }}" style="display:inline;" data-ppo-loading>
                        <button type="submit" class="btn btn-link">{{ 'Dismiss'|trans({}, 'Modules.Ppomniva.Admin') }}</button>
                    </form>
                </div>

                <div class="ppo-migration__result" hidden>
                    <div class="ppo-migration__result-head"></div>
                    <ul class="ppo-migration__log"></ul>
                </div>
            </div>
        </div>
    {% endfor %}

    <script>
    (function () {
        var CONFIRM = {{ 'Import all data from the legacy module and disable it? This cannot be undone.'|trans({}, 'Modules.Ppomniva.Admin')|json_encode|raw }};
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.js-ppo-migrate');
            if (!btn) return;
            var card = btn.closest('.ppo-migration');
            if (!card) return;

            var dry = btn.getAttribute('data-dry') === '1';
            if (!dry && !window.confirm(CONFIRM)) return;

            var buttons = card.querySelectorAll('.js-ppo-migrate');
            buttons.forEach(function (b) { b.disabled = true; });
            var label = btn.textContent;
            btn.textContent = '…';

            var result = card.querySelector('.ppo-migration__result');
            var head = card.querySelector('.ppo-migration__result-head');
            var log = card.querySelector('.ppo-migration__log');

            fetch(card.getAttribute('data-migrate-url'), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: dry ? 'dry_run=1' : ''
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                buttons.forEach(function (b) { b.disabled = false; });
                btn.textContent = label;
                result.hidden = false;
                head.className = 'ppo-migration__result-head ' + (data.success ? 'is-success' : 'is-error');
                head.textContent = '● ' + (data.message || (data.success ? 'Done' : 'Failed'));
                log.innerHTML = '';
                (data.log || []).forEach(function (line) {
                    var li = document.createElement('li');
                    li.textContent = line;
                    log.appendChild(li);
                });
                (data.errors || []).forEach(function (line) {
                    var li = document.createElement('li');
                    li.className = 'is-error';
                    li.textContent = line;
                    log.appendChild(li);
                });
                if (data.success && !dry) {
                    setTimeout(function () { window.location.reload(); }, 2500);
                }
            })
            .catch(function (err) {
                buttons.forEach(function (b) { b.disabled = false; });
                btn.textContent = label;
                result.hidden = false;
                head.className = 'ppo-migration__result-head is-error';
                head.textContent = 'Request failed: ' + err.message;
            });
        });
    })();
    </script>
{% endif %}

{{ form_start(configurationForm, { attr: { 'data-ppo-loading': '' } }) }}

{% set mode = form_mode|default('shop') %}

{# global_toggle: per-store auth is ON, current context is "All shops".
   Credentials are scoped per shop so we don't render them here, only the
   toggle that decides the storage scope. The shop-specific cards live in
   the {% else %} block. #}
{% if mode == 'global_toggle' %}
<div class="ppo-banner-info">
    <strong>{{ 'You are viewing global settings.'|trans({}, 'Modules.Ppomniva.Admin') }}</strong>
    <p>
        {{ 'API credentials, checkout fields and the return-service window are stored per shop. To edit them, switch the shop selector at the top of the admin to a specific shop. The toggle below controls the global "per-store authentication" mode that decides whether each shop holds its own credentials.'|trans({}, 'Modules.Ppomniva.Admin') }}
    </p>
</div>
<div class="ppo-card">
    <div class="ppo-card__header">
        <h3 class="ppo-card__title">{{ 'Per-store authentication'|trans({}, 'Modules.Ppomniva.Admin') }}</h3>
    </div>
    <div class="ppo-card__body ppo-form">
        {{ form_row(configurationForm.store_auth_mode) }}
    </div>
</div>
{% else %}
{# 'shop' (per-shop creds) and 'global_full' (shared creds, edited from
   "All shops") render the same field set. The only difference is that
   global_full appends the per-store auth toggle at the bottom. #}
{% if mode == 'global_full' %}
<div class="ppo-banner-info">
    <strong>{{ 'You are editing shared settings.'|trans({}, 'Modules.Ppomniva.Admin') }}</strong>
    <p>
        {{ 'Per-store authentication is disabled, so the values you save here are used by every shop on this installation.'|trans({}, 'Modules.Ppomniva.Admin') }}
    </p>
</div>
{% endif %}

<div class="ppo-card">
    <div class="ppo-card__header">
        <h3 class="ppo-card__title">{{ 'API credentials'|trans({}, 'Modules.Ppomniva.Admin') }}</h3>
        <span class="ppo-card__help">{{ 'Required to talk to Omniva OMX. The same host serves test and production — the environment is decided by the credentials. Turn Live mode off while validating.'|trans({}, 'Modules.Ppomniva.Admin') }}</span>
    </div>
    <div class="ppo-card__body ppo-form">
        {{ form_row(configurationForm.api_user) }}
        {{ form_row(configurationForm.api_pass) }}
        {{ form_row(configurationForm.agent_id) }}
        {{ form_row(configurationForm.live_mode) }}
    </div>
</div>

<div class="ppo-card">
    <div class="ppo-card__header">
        <h3 class="ppo-card__title">{{ 'Shipping options'|trans({}, 'Modules.Ppomniva.Admin') }}</h3>
        <span class="ppo-card__help">{{ 'Cash on delivery, age-verified delivery, and label format.'|trans({}, 'Modules.Ppomniva.Admin') }}</span>
    </div>
    <div class="ppo-card__body ppo-form">
        {{ form_row(configurationForm.cod_enabled) }}
        {{ form_row(configurationForm['18_plus_service']) }}
        {{ form_row(configurationForm.label_format) }}
    </div>
</div>

{% if mode == 'global_full' %}
<div class="ppo-card">
    <div class="ppo-card__header">
        <h3 class="ppo-card__title">{{ 'Per-store authentication'|trans({}, 'Modules.Ppomniva.Admin') }}</h3>
    </div>
    <div class="ppo-card__body ppo-form">
        {{ form_row(configurationForm.store_auth_mode) }}
    </div>
</div>
{% endif %}
{% endif %}

<div class="ppo-form-actions">
    <button type="submit" class="btn btn-primary">{{ 'Save changes'|trans({}, 'Admin.Actions') }}</button>
    <span style="font-size: var(--ppo-text-sm); color: var(--ppo-text-muted);">
        {{ 'Module version: %v%'|trans({'%v%': module_version|default('?')}, 'Modules.Ppomniva.Admin') }}
    </span>
</div>

{# form_end emits any unrendered children — in particular the CSRF _token
   field that Symfony adds automatically. We used to pass render_rest: false
   here, which stripped the token along with any leftover fields and made
   every save silently fail isValid(). The controller now hands us a
   per-context form (mode='shop' or mode='global') that only contains the
   fields the template renders explicitly, so default form_end is correct. #}
{{ form_end(configurationForm) }}

</div>

<script>
(function () {
    var btn = document.getElementById('ppo-test-connection');
    if (!btn) return;
    var statusEl = document.getElementById('ppo-connection-status');
    var msgEl = document.getElementById('ppo-connection-message');

    btn.addEventListener('click', function () {
        if (window.PPOmnivaAdmin && window.PPOmnivaAdmin.setLoading) {
            window.PPOmnivaAdmin.setLoading(btn, true);
        } else {
            btn.disabled = true;
        }
        statusEl.classList.remove('ppo-status--connected', 'ppo-status--disconnected');
        statusEl.classList.add('ppo-status--unknown');

        fetch(btn.dataset.url, { method: 'POST', credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                msgEl.textContent = data.message || '';
                statusEl.classList.remove('ppo-status--unknown');
                statusEl.classList.add(data.success ? 'ppo-status--connected' : 'ppo-status--disconnected');
            })
            .catch(function (err) {
                msgEl.textContent = err.message || 'Test failed';
                statusEl.classList.remove('ppo-status--unknown');
                statusEl.classList.add('ppo-status--disconnected');
            })
            .finally(function () {
                if (window.PPOmnivaAdmin && window.PPOmnivaAdmin.setLoading) {
                    window.PPOmnivaAdmin.setLoading(btn, false);
                } else {
                    btn.disabled = false;
                }
            });
    });
})();
</script>
{% endif %}
{% endblock %}
